# ─── Database ────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/nimbuspanel"

# ─── App Security ───────────────────────────────────────
# Generate with: openssl rand -hex 16
APP_SECRET=

# ─── AWS (server-side only) ─────────────────────────────
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=nimbuspanel

# ─── Resend Email (server-side only) ────────────────────
RESEND_API_KEY=
EMAIL_FROM=noreply@yourdomain.com

# ─── App URL ────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
