# ─── Database ────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/nimbuspanel"

# ─── App Security ───────────────────────────────────────
APP_SECRET=generate-with-openssl-rand-hex-16
APP_NAME=NimbusPanel

# ─── AWS (server-side only) ─────────────────────────────
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=nimbuspanel

# ─── SMTP (Brevo) ──────────────────────────────────────
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_LOGIN=your-smtp-login@smtp-brevo.com
SMTP_PASSWORD=
EMAIL_FROM=NimbusPanel <noreply@your-verified-domain.com>

# ─── App URL ────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# WebSocket server URL for SSH terminal (separate service in production)
NEXT_PUBLIC_WS_URL=ws://localhost:3000/ws/terminal
