########################################
# APP
########################################
APP_NAME=NimbusPanel
APP_SECRET=generate-with-openssl-rand-hex-16
NEXT_PUBLIC_APP_URL=http://localhost:3000

########################################
# DATABASE
########################################
DATABASE_URL=postgresql://user:password@localhost:5432/nimbuspanel

########################################
# BREVO SMTP
########################################
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_LOGIN=your-login@smtp-brevo.com
SMTP_PASSWORD=
EMAIL_FROM=NimbusPanel <noreply@your-verified-domain.com>

########################################
# AWS S3
########################################
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=nimbuspanel

########################################
# WEBSOCKET (SSH Terminal)
########################################
NEXT_PUBLIC_WS_URL=ws://localhost:3000/ws/terminal
