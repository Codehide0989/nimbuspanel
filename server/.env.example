# ─── Server ─────────────────────────────────────────────
PORT=8080

# ─── Security ───────────────────────────────────────────
# Must match the frontend APP_SECRET (used to decrypt stored credentials)
APP_SECRET=

# ─── Database ───────────────────────────────────────────
# Same database as the Next.js frontend
DATABASE_URL=postgresql://user:password@host:5432/nimbuspanel

# ─── AWS S3 ─────────────────────────────────────────────
# Used to retrieve encrypted PEM keys for SSH connections
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=nimbuspanel

# ─── CORS ───────────────────────────────────────────────
# Frontend origin allowed to connect to this WebSocket server
ALLOWED_ORIGIN=https://nimbuspanel.vercel.app
